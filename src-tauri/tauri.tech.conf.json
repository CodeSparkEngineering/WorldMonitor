{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GeoNexus Tech",
  "mainBinaryName": "geonexus-tech",
  "identifier": "app.geonexus.tech.desktop",
  "app": {
    "windows": [
      {
        "title": "GeoNexus Tech"
      }
    ]
  },
  "bundle": {
    "shortDescription": "GeoNexus Tech desktop app",
    "longDescription": "GeoNexus Tech desktop app for real-time AI and technology intelligence.",
    "targets": [
      "app",
      "dmg",
      "nsis",
      "msi",
      "appimage"
    ],
    "macOS": {
      "hardenedRuntime": true
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "https://timestamp.digicert.com"
    }
  }
}