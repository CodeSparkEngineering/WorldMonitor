{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GeoNexus Finance",
  "mainBinaryName": "geonexus-finance",
  "identifier": "app.geonexus.finance.desktop",
  "app": {
    "windows": [
      {
        "title": "GeoNexus Finance"
      }
    ]
  },
  "bundle": {
    "shortDescription": "GeoNexus Finance desktop app",
    "longDescription": "GeoNexus Finance desktop app for real-time markets and trading intelligence.",
    "targets": [
      "app",
      "dmg",
      "nsis",
      "msi",
      "appimage"
    ],
    "macOS": {
      "hardenedRuntime": true
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "https://timestamp.digicert.com"
    }
  }
}